{
  "required_frontmatter_fields": [
    "id", "title", "summary", "layer", "scope", "applies_to", "type", "stability",
    "source", "evidence", "regression_risk", "supersedes", "last_reviewed", "owner", "status"
  ],
  "allowed_layers": ["core", "platform", "learnings"],
  "allowed_scopes": ["global", "runtime", "repo", "learning"],
  "allowed_statuses": ["active", "draft", "deprecated", "superseded"],
  "secret_patterns": [
    "AKIA[0-9A-Z]{16}",
    "ghp_[A-Za-z0-9]{36,}",
    "gho_[A-Za-z0-9]{36,}",
    "sk-[A-Za-z0-9]{20,}",
    "-----BEGIN (RSA|EC|OPENSSH) PRIVATE KEY-----"
  ]
}
